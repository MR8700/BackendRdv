# .env Render Production Template
# Copier vers .env pour local prod test

NODE_ENV=production
PORT=10000

# Database (Render MySQL/Postgres)
DB_HOST=...
DB_PORT=3306
DB_NAME=clinique_prod
DB_USER=...
DB_PASSWORD=...

# Redis (Render/Upstash)
REDIS_URL=redis://...

# JWT (générer avec openssl rand -base64 64)
JWT_SECRET=...
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=...
JWT_REFRESH_EXPIRES_IN=30d
JWT_BLACKLIST_SECRET=...

# CORS - Frontend Render domain
CORS_ORIGINS=https://frontend-clinique.onrender.com,https://clinique-frontend.vercel.app

# Logs
LOG_LEVEL=warn
LOG_DIR=/opt/render/project/src/logs

# Uploads Render Disk
RENDER_DISK_PATH=/opt/render/disks/uploads
UPLOAD_BASE_DIR=uploads
UPLOAD_MAX_SIZE_MB=5
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/webp

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=5
RATE_LIMIT_MAX_API=100

# Mail (Mailtrap/SES)
MAIL_ENABLED=true
MAIL_TOKEN=...
MAIL_FROM_ADDRESS=no-reply@clinique.app
MAIL_FROM_NAME=Clinique

# Pool DB Prod
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=30000

