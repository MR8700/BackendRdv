# .env.dev - Local Development (copié de env.prod.example)
NODE_ENV=development
PORT=3000

# Local DB (ajustez vos valeurs)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=clinique_dev
DB_USER=root
DB_PASSWORD=password
DB_POOL_MAX=10

# Local Redis (docker run -d -p 6379:6379 redis)
REDIS_URL=redis://localhost:6379

# JWT (générez: openssl rand -base64 64)
JWT_SECRET=your_super_secret_jwt_access_64chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_64chars_min
JWT_REFRESH_EXPIRES_IN=7d
JWT_BLACKLIST_SECRET=your_blacklist_secret

# CORS Local + emulator
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://10.0.2.2:3000

# Logs
LOG_LEVEL=debug
LOG_DIR=logs

# Uploads (local disk pour dev)
UPLOAD_BASE_DIR=uploads
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/webp,application/pdf

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=20
RATE_LIMIT_MAX_API=500

# Mail dev
MAIL_ENABLED=false
MAIL_TOKEN=test
MAIL_FROM_ADDRESS=test@local

